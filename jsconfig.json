{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "checkJs": false,
    "noEmit": true
  },
  "include": ["src/**/*.js", "src/**/*.jsx", "vite.config.js", "eslint.config.js"]
}
